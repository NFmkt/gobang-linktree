# Supabase (공개 — 브라우저에 노출됨)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (비공개 — 서버 전용, 절대 브라우저에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 관리자 인증 (/admin 접속 시 단일 비밀번호)
ADMIN_PASSWORD=change-me

# 배포 도메인 (OG/메타 metadataBase용, 절대 URL 생성). 미설정 시 http://localhost:3939 폴백.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# 제휴 문의 폼(/api/affiliate-inquiries) 전달용 Google Apps Script 웹훅 URL. 미설정 시 문의 제출이 500으로 실패.
GAS_AFFILIATE_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
